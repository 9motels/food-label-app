{
  "version": 2,
  "builds": [
    { "src": "api/products/[id].js", "use": "@vercel/node" },
    { "src": "api/products.js",      "use": "@vercel/node" },
    { "src": "public/**",            "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/products/([^/]+)", "dest": "/api/products/[id].js?id=$1" },
    { "src": "/api/products",         "dest": "/api/products.js" },
    { "src": "/(.*)",                 "dest": "/public/$1" }
  ]
}
